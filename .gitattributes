# Enforce LF line endings on portable source and configuration files so
# clang-format and POSIX tooling behave consistently on Windows checkouts.
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.cxx text eol=lf
*.h text eol=lf
*.hh text eol=lf
*.hpp text eol=lf
*.hxx text eol=lf
*.inl text eol=lf
*.cmake text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
CMakeLists.txt text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.githooks/* text eol=lf
.pre-commit-config.yaml text eol=lf
.clang-format text eol=lf
.clang-tidy text eol=lf
*.sh text eol=lf
*.bash text eol=lf
scripts/vcpkg-triplets/*.cmake text eol=lf
packaging/linux/deb/control.in text eol=lf
packaging/linux/deb/postinst text eol=lf
packaging/linux/deb/prerm text eol=lf
packaging/linux/rpm/*.spec.in text eol=lf

# Keep Windows-native scripts as CRLF.
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

assets/video_samples/*.mp4 filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.png filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.jpg filter=lfs diff=lfs merge=lfs -text
assets/image_samples/**/*.exr filter=lfs diff=lfs merge=lfs -text
